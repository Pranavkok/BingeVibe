{
  "name": "bingevibe",
  "displayName": "BingeVibe",
  "description": "Watch YouTube Shorts while you vibe code.",
  "version": "0.0.2",
  "publisher": "BingeVibe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pranavkok/BingeVibe"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": ["youtube","youtube shorts","yt","bingevibe","instagram","insta","reels","videos","binge","yt videos","movies","short", "shorts", "music", "focus", "coding"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bingevibe.openShorts",
        "title": "BingeVibe: Watch Shorts"
      },
      {
        "command": "bingevibe.resetApiKey",
        "title": "BingeVibe: Reset API Key"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
